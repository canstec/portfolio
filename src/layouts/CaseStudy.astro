---
// Shared layout for every case study page.
// Props let each page set its own <title> and meta description.
// Pass `nextProject` on case-study pages to show the "Next project" footer link.
interface Props {
  title: string;
  description?: string;
  nextProject?: { title: string; url: string };
}
const { title, description = '', nextProject } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..700&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/styles.css" />
  <script src="/script.js" defer></script>
  <script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
</head>
<body>

  <header class="site-header">
    <div class="container nav-row">
      <a href="/" class="brand">Cansu Tecimer</a>
      <nav class="nav">
        <a href="/work/">Work</a>
        <a href="/tinkering/">Tinkering</a>
        <a href="/about/">About</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-row">
      {nextProject && (
        <a href={nextProject.url} class="next-project">
          <span class="eyebrow">Next project</span>
          <span class="next-title">{nextProject.title} &nbsp;→</span>
        </a>
      )}
      <p class="copyright">© 2026 Cansu Tecimer</p>
    </div>
  </footer>

</body>
</html>
